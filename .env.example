# Copy to .env and fill in values

# Backend (local dev without Docker)
DATABASE_URL=postgresql://demo:demo@localhost:5433/demo
JWT_SECRET=change-me-in-production
PORT=3000

# SSO integration (optional — leave empty to disable SSO button)
# Register a client via: POST https://accounts.freiding.by/admin/clients
# (requires ADMIN_API_KEY from the SSO server)
SSO_ISSUER=https://accounts.freiding.by
SSO_CLIENT_ID=
SSO_CLIENT_SECRET=

# Ethereum RPC URL — required for staking (approve + deposit need sequential confirmation)
ETH_RPC_URL=

# Production docker-compose overrides
POSTGRES_USER=demo
POSTGRES_PASSWORD=demo
POSTGRES_DB=demo
